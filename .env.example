# Environment Variables – HealixAI (HIPAA-Compliant)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── PHI Encryption (REQUIRED for HIPAA compliance) ────────────────────────
# AES-256 passphrase – minimum 32 characters, randomly generated.
# Generate with: openssl rand -base64 32
VITE_PHI_ENCRYPTION_KEY=REPLACE_WITH_MIN_32_CHAR_RANDOM_STRING

# ─── AI Backend ─────────────────────────────────────────────────────────────
# Gemini API key for the AI backend (server.ts).
# This is used by server.ts (Node.js) only – NEVER expose to the browser.
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Legacy NVIDIA NIM key (if still used by any routes).
# NVIDIA_API_KEY=REPLACE_WITH_YOUR_NVIDIA_API_KEY

# ─── Firebase (auto-populated from firebase-applet-config.json) ─────────────
# Do NOT add Firebase credentials here – they are read from the JSON config.
# The JSON config is safe to commit because Firebase security rules enforce access.

# ─── Session (optional overrides) ───────────────────────────────────────────
# VITE_SESSION_TIMEOUT_MS=900000   # 15 minutes (HIPAA default)
